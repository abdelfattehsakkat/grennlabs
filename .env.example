# === Backend ===
JWT_SECRET=change_me_in_production_use_64_random_chars
JWT_EXPIRES_IN=8h

# === MongoDB ===
# Port 27022 est pour l'hôte (Robo3T, etc.), le backend utilise 27017 (réseau Docker interne)
MONGO_ROOT_USERNAME=greenit_admin
MONGO_ROOT_PASSWORD=change_me_strong_password_here
MONGO_URI=mongodb://greenit_admin:change_me_strong_password_here@mongodb:27017/greenit?authSource=admin

# En DEV local :
FRONTEND_URL=http://localhost:3005
# En PROD (à modifier selon votre IP/domaine) :
# FRONTEND_URL=http://51.178.141.50:3005

# === Frontend ===
# En DEV local :
NEXT_PUBLIC_API_URL=http://localhost:3006
# En PROD (à modifier selon votre IP/domaine) :
# NEXT_PUBLIC_API_URL=http://51.178.141.50:3006
PORT=3005

# === Prod (VPS OVH) ===
# NEXT_PUBLIC_API_URL=https://yourdomain.com/api
# DOMAIN=yourdomain.com
